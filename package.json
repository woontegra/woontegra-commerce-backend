{
  "name": "woontegra-backend",
  "version": "1.0.0",
  "description": "Scalable e-commerce SaaS backend with multi-tenant support",
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc",
    "build:ci": "tsc --noEmit -p tsconfig.ci.json",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "vitest run && vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "start": "node dist/main.js",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "promote:super-admin": "node scripts/promote-owner-to-super-admin.js",
    "migrate:trendyol-credentials": "ts-node --transpile-only scripts/migrate-trendyol-credentials.ts",
    "test:credential-crypto": "ts-node --transpile-only scripts/test-marketplace-credential-crypto.ts",
    "email:test": "ts-node --transpile-only scripts/send-test-email.ts",
    "email:send": "ts-node --transpile-only scripts/send-test-email.ts",
    "seed:demo": "ts-node --transpile-only scripts/seed-demo-store.ts",
    "backfill:order-payments": "ts-node --transpile-only scripts/backfill-order-payment-fields.ts",
    "backfill:order-payments:dry": "ts-node --transpile-only scripts/backfill-order-payment-fields.ts",
    "backfill:order-payments:write": "ts-node --transpile-only scripts/backfill-order-payment-fields.ts --write"
  },
  "keywords": [
    "ecommerce",
    "saas",
    "multi-tenant"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.2",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@bull-board/api": "^7.0.0",
    "@bull-board/express": "^7.0.0",
    "@bull-board/ui": "^7.0.0",
    "@prisma/client": "^5.22.0",
    "@types/json2csv": "^5.0.7",
    "@types/nodemailer": "^8.0.0",
    "axios": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.73.0",
    "cors": "^2.8.6",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "fast-xml-parser": "^5.5.10",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "iyzipay": "^2.0.67",
    "joi": "^18.1.2",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.3",
    "meilisearch": "^0.57.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.4",
    "prisma": "^5.22.0",
    "puppeteer": "^24.42.0",
    "sharp": "^0.34.5",
    "stripe": "^22.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  }
}
