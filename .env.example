DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/woontegra"
# Railway local dev: public proxy host (e.g. *.proxy.rlwy.net), NOT postgres.railway.internal
JWT_SECRET="supersecret"
JWT_REFRESH_SECRET="supersecret-refresh"
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# App URLs
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Logging (Winston — JSON dosya + konsol)
LOG_LEVEL=info
LOG_DIR=logs
LOG_FILE=true
LOG_CONSOLE=true
# Error alert (Slack veya Discord incoming webhook)
# LOG_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
# LOG_ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Integration tests (ayrı PostgreSQL önerilir)
# Integration tests — ONLY on local test DB (never Railway/production DATABASE_URL)
# RUN_INTEGRATION_TESTS=true
# INTEGRATION_DATABASE_URL=postgresql://test:test@localhost:5432/woontegra_test
# NEVER: ALLOW_INTEGRATION_ON_ANY_DB=true with Railway/production URL (deletes all users)
# INTEGRATION_DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/woontegra_test

# Payment Provider (stripe or iyzico)
PAYMENT_PROVIDER=stripe

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# iyzico Configuration
IYZICO_API_KEY=your_iyzico_api_key
IYZICO_SECRET_KEY=your_iyzico_secret_key
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Payment Provider
PAYMENT_PROVIDER=iyzico

# Trendyol / marketplace API credentials (AES-256-CBC) — zorunlu, min 16 karakter (önerilen 32+)
# openssl rand -hex 32
MARKETPLACE_ENCRYPTION_KEY=

# E-posta (Resend veya SMTP)
EMAIL_PROVIDER=resend
EMAIL_API_KEY=re_your_resend_api_key
EMAIL_FROM=onboarding@yourdomain.com
EMAIL_FROM_NAME=Woontegra
# SMTP (EMAIL_PROVIDER=smtp)
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USER=apikey
# EMAIL_QUEUE_ATTEMPTS=5
# EMAIL_QUEUE_BACKOFF_MS=3000

# CDN Configuration
CDN_ENABLED=false
CDN_BASE_URL=https://cdn.yourdomain.com
CDN_UPLOAD_PATH=/uploads

# PayTR — mağaza vitrini sipariş ödemeleri (tenant bazlı ayar ileride DB'ye taşınacak)
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
PAYTR_TEST_MODE=true
PAYTR_CALLBACK_URL=
# Opsiyonel; boşsa FRONTEND_URL + /store/odeme-basarili|basarisiz kullanılır
PAYTR_SUCCESS_URL=
PAYTR_FAIL_URL=

# Tenant hostname çözümleme (örn. shop.woontegra.com → shop)
TENANT_PLATFORM_BASE_DOMAIN=

# Custom domain DNS doğrulama (POST .../domains/verify)
DOMAIN_VERIFY_CNAME_TARGET=app.woontegra.com
DOMAIN_VERIFY_A_IPV4=
DOMAIN_VERIFY_A_IPV6=