// ─── Billing ─────────────────────────────────────────────────────────────────

enum SubscriptionStatus {
  PENDING
  ACTIVE
  CANCELED
  EXPIRED
  PAST_DUE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

model Subscription {
  id           String             @id @default(uuid())
  tenantId     String
  userId       String
  plan         Plan
  billingCycle BillingCycle       @default(MONTHLY)
  status       SubscriptionStatus @default(PENDING)
  startDate    DateTime           @default(now())
  endDate      DateTime
  canceledAt   DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments Payment[]
  invoices Invoice[]

  @@index([tenantId, status])
  @@index([endDate])
  @@map("subscriptions")
}

model Payment {
  id             String        @id @default(uuid())
  tenantId       String
  subscriptionId String
  userId         String
  amount         Decimal       @db.Decimal(10, 2)
  currency       String        @default("TRY")
  status         PaymentStatus @default(PENDING)
  provider       String        @default("iyzico")
  transactionId  String?
  iyzicoToken    String?       @unique
  metadata       Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices     Invoice[]

  @@index([tenantId])
  @@index([iyzicoToken])
  @@map("payments")
}

// ─── Invoices ─────────────────────────────────────────────────────────────────

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
}

enum InvoiceType {
  SUBSCRIPTION      // normal dönem faturası
  UPGRADE_PRORATION // upgrade farkı (pro-rate)
  DOWNGRADE_CREDIT  // downgrade alacak notu (negatif tutar)
  MANUAL            // admin el ile oluşturdu
}

model Invoice {
  id             String        @id @default(uuid())
  tenantId       String
  subscriptionId String?
  paymentId      String?
  type           InvoiceType   @default(SUBSCRIPTION)
  status         InvoiceStatus @default(DRAFT)
  number         String        @unique
  currency       String        @default("TRY")
  subtotal       Decimal       @db.Decimal(10, 2)
  tax            Decimal       @default(0) @db.Decimal(10, 2)
  total          Decimal       @db.Decimal(10, 2)
  description    String?
  lineItems      Json          @default("[]")
  dueDate        DateTime?
  paidAt         DateTime?
  voidedAt       DateTime?
  periodStart    DateTime?
  periodEnd      DateTime?
  metadata       Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  payment      Payment?      @relation(fields: [paymentId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
  @@map("invoices")
}

// ─── Feature Flags ───────────────────────────────────────────────────────────

model Feature {
  id          String          @id @default(uuid())
  key         String          @unique
  name        String
  description String?
  category    String          @default("general")
  defaultOn   Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  tenantFeatures TenantFeature[]

  @@map("features")
}

model TenantFeature {
  id        String   @id @default(uuid())
  tenantId  String
  featureId String
  enabled   Boolean  @default(false)
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  feature Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([tenantId, featureId])
  @@index([tenantId])
  @@map("tenant_features")
}

// ─── Audit Log ───────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())

  // Who
  userId     String?       // null = system / cron
  userEmail  String?
  userRole   String?       // USER | ADMIN | SUPER_ADMIN | system
  tenantId   String?       // null = platform-level action

  // Backward compat aliases (kept for existing queries)
  adminId    String?
  adminEmail String?

  // What
  action     String        // e.g. LOGIN, ORDER_CREATED, SUBSCRIPTION_CANCELED
  category   String        @default("GENERAL")  // AUTH | BILLING | ORDER | TENANT | USER | SYSTEM
  targetType String        // e.g. User, Tenant, Order, Subscription, Payment
  targetId   String        @default("")
  targetName String?

  // Result
  status     String        @default("SUCCESS")  // SUCCESS | FAILURE | WARNING
  errorMsg   String?

  // Context
  ipAddress  String?
  userAgent  String?
  details    Json?         // full payload / diff

  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([tenantId])
  @@index([action])
  @@index([category])
  @@index([status])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ── Trendyol Integration Logs ─────────────────────────────────────────────────
model IntegrationLog {
  id              String   @id @default(uuid())
  tenantId        String
  productId       String?
  productName     String?
  batchId         String?
  status          String   // 'pending' | 'sending' | 'success' | 'error' | 'skipped'
  message         String?
  requestPayload  Json?
  responsePayload Json?
  createdAt       DateTime @default(now())

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([tenantId, batchId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("integration_logs")
}

// ─── Trendyol Ürün Bazlı Ayarlar ─────────────────────────────────────────────
// Her ürün için ayrı kategori / marka / özellik / fiyat stratejisi override'ı.
// isOverride=false ise toplu ayarlar kullanılır; true ise bu kayıt önceliklidir.

model TrendyolProductSettings {
  id               String   @id @default(uuid())
  tenantId         String
  productId        String   @unique            // Bir ürüne tek kayıt
  trendyolCategoryId String?                   // Trendyol kategori ID (string)
  trendyolBrandId    Int?                      // Trendyol marka ID
  attributes       Json     @default("{}")     // { "attrId": valueId | "customValue" }
  priceType        String   @default("none")   // none | percentage | fixed
  priceValue       Decimal  @default(0) @db.Decimal(10, 2)
  cargoCompanyId   Int?
  deliveryDuration Int?
  vatRate          Int      @default(18)
  isOverride       Boolean  @default(true)     // true = bu ayarlar geçerli
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("trendyol_product_settings")
}

// ─── Trendyol Fiyat/Stok Sync Queue ─────────────────────────────────────────
// Her fiyat/stok değişikliğinde bu kuyruğa eklenir.
// Worker her 2 dakikada tenant bazında max 100'lük batchler halinde Trendyol'a gönderir.

model TrendyolSyncQueue {
  id          String   @id @default(uuid())
  tenantId    String
  barcode     String
  listPrice   Decimal  @db.Decimal(10, 2)
  salePrice   Decimal  @db.Decimal(10, 2)
  quantity    Int
  status      String   @default("pending")   // pending | processing | success | error
  errorMsg    String?
  attempts    Int      @default(0)           // kaç kez denendi
  processedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([tenantId, barcode])
  @@index([status, createdAt])
  @@map("trendyol_sync_queue")
}

model ApiKey {
  id          String   @id @default(uuid())
  name        String
  key         String   @unique
  prefix      String
  
  rateLimit   Int      @default(100)
  requestCount Int     @default(0)
  lastReset   DateTime @default(now())
  
  permissions Json?
  
  isActive    Boolean  @default(true)
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  
  tenantId    String
  userId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([key])
  @@index([prefix])
  @@map("api_keys")
}
