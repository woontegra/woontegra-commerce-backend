generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                   String                @id @default(uuid())
  name                 String
  slug                 String                @unique
  isActive             Boolean               @default(true)
  status               TenantStatus          @default(TRIAL)
  trialEndsAt          DateTime?
  suspendedAt          DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  customDomain         String?               @unique
  domainVerified       Boolean               @default(false)
  subdomain            String?               @unique
  abandonedCarts       AbandonedCart[]
  activityLogs         ActivityLog[]
  apiTokens            ApiToken[]
  webhooks             Webhook[]
  b2bProfiles          B2BProfile[]
  campaigns            Campaign[]
  carts                Cart[]
  categories           Category[]
  coupons              Coupon[]
  customerGroups       CustomerGroup[]
  customers            Customer[]
  discountRules        DiscountRule[]
  importLogs           ImportLog[]
  logs                 Log[]
  notifications        Notification[]
  orders               Order[]
  pages                Page[]
  posts                Post[]
  productStats         ProductStats[]
  products             Product[]
  searchHistory        SearchHistory[]
  settings             Settings?
  shippingMethods      ShippingMethod[]
  Stock                Stock[]
  syncHistories        SyncHistory[]
  trendyolIntegrations  TrendyolIntegration[]
  trendyolProductMaps   TrendyolProductMap[]
  trendyolProductPrices TrendyolProductPrice[]
  trendyolOrders           TrendyolOrder[]
  trendyolSyncQueue        TrendyolSyncQueue[]
  trendyolProductSettings  TrendyolProductSettings[]
  users                User[]
  marketplaceAccounts    MarketplaceAccount[]
  marketplaceProductMaps MarketplaceProductMap[]
  attributes             Attribute[]
  marketplaceOrders      MarketplaceOrder[]
  marketplaceSyncLogs    MarketplaceSyncLog[]
  subscriptions          Subscription[]
  payments               Payment[]
  tenantFeatures         TenantFeature[]
  invoices               Invoice[]
  integrationLogs        IntegrationLog[]
  brands                 Brand[]
  wishlists              Wishlist[]
  popups                 Popup[]
  shippingRules          ShippingRule[]
  stores                 Store[]
  exchangeRates          ExchangeRate[]
  apiKeys                ApiKey[]

  @@map("tenants")
}

model User {
  id              String           @id @default(uuid())
  email           String
  password        String
  firstName       String
  lastName        String
  role            UserRole         @default(USER)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  tenantId        String
  plan            Plan             @default(STARTER)
  AbandonedCart   AbandonedCart[]
  B2BProfile      B2BProfile?
  Cart            Cart[]
  ImportLog       ImportLog[]
  Post            Post[]
  Wishlist        Wishlist?
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscriptions   Subscription[]
  payments        Payment[]
  userPermissions UserPermission[]

  @@unique([email, tenantId])
  @@map("users")
}

// ─── Granular per-user permission overrides ───────────────────────────────────
// Role defaults are code-defined; this table stores ONLY explicit overrides.
// granted=true  → grant even if role wouldn't allow
// granted=false → revoke even if role would allow
model UserPermission {
  id        String   @id @default(uuid())
  userId    String
  key       String   // e.g. "product.create", "order.view"
  granted   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
  @@map("user_permissions")
}

model CustomerGroup {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenantId  String
  customers Customer[]
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([name, tenantId])
  @@map("customer_groups")
}

model Customer {
  id        String   @id @default(uuid())
  email     String
  firstName String
  lastName  String
  phone     String?
  address   String?
  city      String?
  country   String?
  zipCode   String?
  groupId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  group     CustomerGroup? @relation(fields: [groupId], references: [id])
  orders    Order[]

  @@unique([email, tenantId])
  @@map("customers")
}

model Category {
  id              String     @id @default(uuid())
  name            String
  slug            String
  description     String?
  parentId        String?
  // ── Tree metadata ─────────────────────────────────────────────────────────
  level           Int        @default(0)    // 0 = kök, 1 = alt, 2 = alt-alt ...
  path            String     @default("")   // örn: "elektronik/telefonlar/akilli-telefonlar"
  order           Int        @default(0)    // aynı seviyede sıralama
  isActive        Boolean    @default(true)
  // ── Görsel & İkon ─────────────────────────────────────────────────────────
  imageUrl        String?
  icon            String?    // emoji veya icon kodu
  // ── SEO ──────────────────────────────────────────────────────────────────
  metaTitle       String?
  metaDescription String?
  // ── Timestamps ────────────────────────────────────────────────────────────
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  tenantId        String
  parent          Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children        Category[] @relation("CategoryHierarchy")
  tenant          Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products        Product[]
  categoryAttributes CategoryAttribute[]

  @@unique([slug, tenantId])
  @@index([tenantId, level])
  @@index([tenantId, parentId])
  @@index([tenantId, path])
  @@map("categories")
}

// ─── Attribute System ─────────────────────────────────────────────────────────

model Attribute {
  id           String             @id @default(uuid())
  name         String
  slug         String             // e.g. "renk", "numara"
  type         String             // select | multiselect | text | number | boolean | color
  unit         String?            // e.g. "cm", "kg" (for number type)
  isFilterable Boolean            @default(true)
  isRequired   Boolean            @default(false)
  displayOrder Int                @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  tenantId     String
  tenant            Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  values            AttributeValue[]
  categories        CategoryAttribute[]
  productValues     ProductAttributeValue[]
  variantAttributes VariantAttribute[]

  @@unique([slug, tenantId])
  @@index([tenantId])
  @@map("attributes")
}

model AttributeValue {
  id           String    @id @default(uuid())
  value        String    // internal value key  e.g. "kirmizi"
  label        String    // display label       e.g. "Kırmızı"
  color        String?   // hex color for color-type attributes
  displayOrder Int       @default(0)
  attributeId  String
  attribute         Attribute              @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  productValues     ProductAttributeValue[]
  variantAttributes VariantAttribute[]

  @@index([attributeId])
  @@map("attribute_values")
}

model CategoryAttribute {
  id           String    @id @default(uuid())
  categoryId   String
  attributeId  String
  required     Boolean   @default(false)
  isVariant    Boolean   @default(false)   // true → feeds variant engine
  displayOrder Int       @default(0)
  category     Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  attribute    Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([categoryId, attributeId])
  @@index([categoryId])
  @@map("category_attributes")
}

model ProductAttributeValue {
  id               String          @id @default(uuid())
  productId        String
  attributeId      String
  // For text/number/boolean: raw value stored here
  value            String?
  // For select/multiselect: references to AttributeValue
  attributeValueId String?
  product          Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute        Attribute       @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  attributeValue   AttributeValue? @relation(fields: [attributeValueId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([attributeId])
  @@map("product_attribute_values")
}

model Product {
  id                String             @id @default(uuid())
  name              String
  slug              String
  description       String?
  // ── Legacy price field (kept for backward compat with OrderItem/CartItem) ──
  price             Decimal            @db.Decimal(10, 2)
  sku               String?
  barcode           String?   @unique  // Barkod (EAN-13 / QR) — globally unique
  isAutoBarcode     Boolean   @default(false)  // true = system-generated, false = user-provided (immutable)
  unit              String             @default("adet")  // adet | kg | metre | litre | paket
  brand             String?            // Marka
  status            String             @default("active") // active | draft | archived
  isActive          Boolean            @default(true)
  images            String[]           // legacy — ProductImage relation is preferred
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  tenantId          String
  categoryId        String?
  basePrice         Decimal?           @db.Decimal(10, 2)
  customFields      Json?
  hasVariants       Boolean            @default(false)
  maxQuantity       Int?
  minQuantity       Int                @default(1)
  stepQuantity      Int                @default(1)
  unitType          String             @default("piece")
  unitValue         Decimal            @default(1) @db.Decimal(10, 2)
  variantOptions    Json?
  taxRate           Decimal            @default(20) @db.Decimal(5, 2) // KDV oranı (%)
  storeId           String?
  cartItems         CartItem[]
  customFieldValues CustomFieldValue[]
  orderItems        OrderItem[]
  productStats      ProductStats?
  variants          ProductVariant[]
  wishlistItems     WishlistItem[]
  category          Category?          @relation(fields: [categoryId], references: [id])
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store             Store?             @relation(fields: [storeId], references: [id], onDelete: SetNull)
  stock             Stock?
  marketplaceProductMaps MarketplaceProductMap[]
  trendyolMaps            TrendyolProductMap[]
  integrationLogs         IntegrationLog[]
  trendyolProductPrice    TrendyolProductPrice?
  trendyolProductSettings TrendyolProductSettings?
  // ── New domain relations ──────────────────────────────────────────────────
  pricing           ProductPrice?
  shipping          ProductShipping?
  productImages     ProductImage[]
  attributeValues   ProductAttributeValue[]
  translations      ProductTranslation[]

  @@unique([slug, tenantId])
  @@index([tenantId, status])
  @@index([tenantId, categoryId])
  @@map("products")
}

model ProductVariant {
  id                String             @id @default(uuid())
  name              String
  price             Decimal?           @db.Decimal(10, 2)   // override: null = inherit product price
  discountPrice     Decimal?           @db.Decimal(10, 2)   // override: null = inherit product discountPrice
  wholesalePrice    Decimal?           @db.Decimal(10, 2)   // toptan fiyatı
  groupPrices       Json?                                  // {groupId: price}
  sku               String?            @unique
  barcode           String?   @unique  // globally unique — auto-generated if not set by user
  isAutoBarcode     Boolean   @default(false)
  stockQuantity     Decimal            @default(0) @db.Decimal(10, 3)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  productId         String
  combination       Json               @default("{}")   // legacy cache: {"Renk":"Kırmızı","Numara":"38"}
  images            String[]
  cartItems         CartItem[]
  orderItems        OrderItem[]
  wishlistItems     WishlistItem[]
  product           Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantAttributes VariantAttribute[]  // relational attribute mapping

  @@index([productId])
  @@index([productId, isActive])
  @@map("product_variants")
}

// ─── Variant ↔ Attribute relational mapping ──────────────────────────────────

model VariantAttribute {
  id             String          @id @default(uuid())
  variantId      String
  attributeId    String
  valueId        String?         // set for select/multiselect/color attrs
  textValue      String?         // set for free-text/number attrs

  variant        ProductVariant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attribute      Attribute       @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  attributeValue AttributeValue? @relation(fields: [valueId], references: [id], onDelete: SetNull)

  @@unique([variantId, attributeId])
  @@index([variantId])
  @@index([attributeId])
  @@map("variant_attributes")
}

// ─── Product Price (ayrı fiyatlandırma tablosu) ──────────────────────────────

model ProductPrice {
  id            String   @id @default(uuid())
  productId     String   @unique
  salePrice     Decimal  @db.Decimal(10, 2)
  purchasePrice Decimal? @db.Decimal(10, 2)  // Alış fiyatı
  discountPrice Decimal? @db.Decimal(10, 2)  // İndirimli fiyat
  vatRate       Decimal  @default(18) @db.Decimal(5, 2)
  currency      String   @default("TRY")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_prices")
}

// ─── Product Shipping (kargo bilgileri) ──────────────────────────────────────

model ProductShipping {
  id               String   @id @default(uuid())
  productId        String   @unique
  weight           Decimal? @db.Decimal(10, 3)   // kg
  width            Decimal? @db.Decimal(10, 2)   // cm
  height           Decimal? @db.Decimal(10, 2)   // cm
  length           Decimal? @db.Decimal(10, 2)   // cm
  desi             Decimal? @db.Decimal(10, 2)   // otomatik veya manuel
  freeShipping     Boolean  @default(false)
  shippingCost     Decimal? @db.Decimal(10, 2)
  // Trendyol-specific
  cargoCompanyId   Int?                           // Trendyol cargo company ID (e.g. 10=MNG, 4=Yurtiçi)
  deliveryDuration Int?                           // delivery days (e.g. 3)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_shipping")
}

// ─── Product Image (sıralı görsel tablosu) ───────────────────────────────────

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  url       String
  order     Int      @default(0)
  isMain    Boolean  @default(false)
  alt       String?
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, order])
  @@map("product_images")
}

model Order {
  id               String          @id @default(uuid())
  orderNumber      String          @unique
  status           OrderStatus     @default(PENDING)
  totalAmount      Decimal         @db.Decimal(10, 2)
  currency         String          @default("TRY")
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  tenantId         String
  customerId       String
  shippingMethodId String?
  shippingPrice    Decimal         @default(0) @db.Decimal(10, 2)
  couponId         String?
  discountAmount   Decimal         @default(0) @db.Decimal(10, 2)
  campaignDiscount Decimal         @default(0) @db.Decimal(10, 2)
  items            OrderItem[]
  coupon           Coupon?         @relation(fields: [couponId], references: [id])
  customer         Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  shippingMethod   ShippingMethod? @relation(fields: [shippingMethodId], references: [id])
  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([customerId])
  @@map("orders")
}

model OrderItem {
  id             String          @id @default(uuid())
  quantity       Int
  price          Decimal         @db.Decimal(10, 2)
  discountAmount Decimal         @default(0) @db.Decimal(10, 2)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  orderId        String
  productId      String
  variantId      String?
  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

model Settings {
  id             String   @id @default(uuid())
  siteName       String   @default("My Store")
  logo           String?           // legacy — kept for BC
  logoUrl        String?           // uploaded logo URL
  faviconUrl     String?           // uploaded favicon URL
  primaryColor   String   @default("#3B82F6")
  secondaryColor String?  @default("#10B981")
  accentColor    String?  @default("#F59E0B")
  fontFamily     String?  @default("Inter")
  borderRadius   String?  @default("0.5rem")  // e.g. "0rem" | "0.5rem" | "1rem"
  customCss      String?           // advanced: tenant-injected CSS
  currency       String   @default("USD")
  language       String   @default("en")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenantId       String   @unique
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("settings")
}

model Page {
  id          String   @id @default(uuid())
  title       String
  slug        String
  sections    Json     @default("[]")
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([slug, tenantId])
  @@map("pages")
}

model Cart {
  id        String     @id @default(uuid())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  tenantId  String
  userId    String?
  items     CartItem[]
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@map("carts")
}

model CartItem {
  id        String          @id @default(uuid())
  quantity  Int             @default(1)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  cartId    String
  productId String
  variantId String?
  cart      Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([cartId, productId, variantId])
  @@map("cart_items")
}

model ShippingMethod {
  id            String   @id @default(uuid())
  name          String
  description   String?
  price         Decimal  @db.Decimal(10, 2)
  estimatedDays Int?     @default(3)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenantId      String
  orders        Order[]
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("shipping_methods")
}

model Coupon {
  id             String       @id @default(uuid())
  code           String       @unique
  discountType   DiscountType @default(PERCENTAGE)
  value          Decimal      @db.Decimal(10, 2)
  minOrderAmount Decimal?     @db.Decimal(10, 2)
  maxDiscount    Decimal?     @db.Decimal(10, 2)
  usageLimit     Int?         @default(0)
  usageCount     Int          @default(0)
  isActive       Boolean      @default(true)
  expiresAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders         Order[]

  @@map("coupons")
}

model Post {
  id          String    @id @default(uuid())
  title       String
  slug        String
  content     String
  excerpt     String?
  coverImage  String?
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenantId    String
  authorId    String
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([slug, tenantId])
  @@map("posts")
}

model ApiToken {
  id         String    @id @default(uuid())
  name       String
  token      String    @unique
  scopes     String[]  @default([])  // e.g. ["products:read","orders:write"]
  lastUsedAt DateTime?
  expiresAt  DateTime?
  isActive   Boolean   @default(true)
  rateLimit  Int       @default(1000) // requests per hour
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("api_tokens")
}

// ─── Webhooks ─────────────────────────────────────────────────────────────────

model Webhook {
  id          String       @id @default(uuid())
  tenantId    String
  url         String
  secret      String       // HMAC-SHA256 signing secret
  events      String[]     // ["order.created", "payment.success", ...]
  description String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  logs        WebhookLog[]

  @@index([tenantId])
  @@map("webhooks")
}

model WebhookLog {
  id          String    @id @default(uuid())
  webhookId   String
  event       String
  payload     Json
  statusCode  Int?
  response    String?   // truncated response body
  success     Boolean
  attempts    Int       @default(1)
  nextRetryAt DateTime?
  createdAt   DateTime  @default(now())
  webhook     Webhook   @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([event])
  @@index([success])
  @@map("webhook_logs")
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  tenantId  String
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Campaign {
  id                 String           @id @default(uuid())
  name               String
  description        String?
  code               String?          @unique
  discountType       CampaignType
  discountPercentage Int?
  discountAmount     Decimal?         @db.Decimal(10, 2)
  buyQuantity        Int?
  getQuantity        Int?
  maxDiscount        Decimal?         @db.Decimal(10, 2)
  rules              Json
  startDate          DateTime
  endDate            DateTime
  usageLimit         Int?
  usagePerUser       Int?
  currentUsage       Int              @default(0)
  isActive           Boolean          @default(true)
  priority           Int              @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  tenantId           String
  usage              CampaignUsage[]
  campaignRules      CampaignRule[]
  tenant             Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive])
  @@map("campaigns")
}

model CampaignRule {
  id         String           @id @default(uuid())
  campaignId String
  type       CampaignRuleType
  conditions Json             @default("{}")
  actions    Json             @default("{}")
  priority   Int              @default(0)
  isActive   Boolean          @default(true)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  campaign   Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("campaign_rules")
}

model CampaignUsage {
  id             String   @id @default(uuid())
  discountAmount Decimal  @db.Decimal(10, 2)
  usedAt         DateTime @default(now())
  campaignId     String
  userId         String
  orderId        String?
  campaign       Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("campaign_usage")
}

model Log {
  id          String   @id @default(uuid())
  type        LogType
  level       LogLevel
  action      String
  description String?
  userId      String?
  userName    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([type])
  @@index([level])
  @@index([userId])
  @@index([createdAt])
  @@map("logs")
}

model CustomFieldValue {
  id        String   @id @default(uuid())
  fieldId   String
  value     String
